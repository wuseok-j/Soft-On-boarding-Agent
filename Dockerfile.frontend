# --- Build Stage ---
FROM node:20-alpine AS build
WORKDIR /app/frontend

# Copy package.json and install dependencies
COPY frontend/package*.json ./
RUN npm install

# Copy source files
COPY frontend/ ./

# Delete local .env files so they don't hardcode localhost during Docker build
RUN rm -f .env .env.local .env.development

# Define build argument for the API base URL.
# Since we are using an Nginx reverse proxy to route /api to the backend,
# the frontend should just call its own origin (e.g. '/' or '')
ENV VITE_API_BASE_URL=""

# Build the React app
RUN npm run build

# --- Final Stage ---
FROM nginx:alpine
# Copy built static files
COPY --from=build /app/frontend/dist /usr/share/nginx/html
# Copy custom nginx configuration
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
